{
  "expo": {
    "name": "Intown",
    "slug": "intownlocal",
    "version": "1.2.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "intown",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vinodreddy.intownlocal",
      "config": {
        "googleMapsApiKey": "AIzaSyBTPqSDYbyIbJZetJ8Shd_DOqywUJN55AA"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF8A00"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBTPqSDYbyIbJZetJ8Shd_DOqywUJN55AA"
        }
      },
      "package": "com.intown.andriod"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow IntownLocal to use your location to find nearby shops."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      "./plugins/withUpiQueries",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow IntownLocal to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow IntownLocal to securely recognize your speech for voice search.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "fonts": [
      "./assets/fonts/Inter/static/Inter_18pt-Regular.ttf",
      "./assets/fonts/Inter/static/Inter_18pt-Medium.ttf",
      "./assets/fonts/Inter/static/Inter_18pt-SemiBold.ttf",
      "./assets/fonts/Inter/static/Inter_18pt-Bold.ttf"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f515f57-74ba-4b3b-aa12-797ce811fdd6"
      }
    }
  }
}
