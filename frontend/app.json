{
  "expo": {
    "name": "INtown",
    "slug": "intownlocal",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "intownlocal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vinodreddy.intownlocal",
      "buildNumber": "22",
      "config": {
        "googleMapsApiKey": "AIzaSyBTPqSDYbyIbJZetJ8Shd_DOqywUJN55AA"
      }
    },

    "android": {
      "versionCode": 22,
      "package": "com.intown.andriod",

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.jpeg",
        "backgroundColor": "#FF8A00"
      },

      "edgeToEdgeEnabled": true,

      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],

      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBTPqSDYbyIbJZetJ8Shd_DOqywUJN55AA"
        }
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.jpeg"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],

      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow IntownLocal to use your location to find nearby shops."
        }
      ],

      "expo-build-properties",

      "./plugins/withUpiQueries"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "fonts": [
      "./assets/fonts/Inter/static/Inter_18pt-Regular.ttf",
      "./assets/fonts/Inter/static/Inter_18pt-Medium.ttf",
      "./assets/fonts/Inter/static/Inter_18pt-SemiBold.ttf",
      "./assets/fonts/Inter/static/Inter_18pt-Bold.ttf"
    ],

    "extra": {
      "router": {},

      "eas": {
        "projectId": "2f515f57-74ba-4b3b-aa12-797ce811fdd6"
      }
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}