/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ────────────────────────────────────────────────────────────
# Testing
# ────────────────────────────────────────────────────────────
/coverage

# ────────────────────────────────────────────────────────────
