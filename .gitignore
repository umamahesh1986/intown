/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ────────────────────────────────────────────────────────────
# Production builds
# ────────────────────────────────────────────────────────────
/build
dist/
dist
.cache/

# ────────────────────────────────────────────────────────────
# Expo / React Native
# ────────────────────────────────────────────────────────────
.expo/
.metro/
.metro-cache/
.metro-health-check*
web-build/
expo-env.d.ts

# ────────────────────────────────────────────────────────────
# Expo prebuild — native folders are generated from app.json + plugins
# Run `npx expo prebuild` to regenerate. Do not edit ios/ or android/ by hand —
# put native config in app.json plugins or a custom plugin under ./plugins/.
# ────────────────────────────────────────────────────────────
frontend/ios/
frontend/android/

# ────────────────────────────────────────────────────────────
# iOS / Xcode (user-state and build artifacts — safety net if ios/ ever
# becomes tracked again, these are never wanted)
# ────────────────────────────────────────────────────────────
**/ios/Pods/
**/ios/build/
**/ios/DerivedData/
**/ios/.xcode.env.local
**/xcuserdata/
**/*.xcuserstate
**/*.hmap
**/*.ipa

# ────────────────────────────────────────────────────────────
# Android / Gradle (user-state and build artifacts — safety net)
# ────────────────────────────────────────────────────────────
**/android/build/
**/android/app/build/
**/android/.gradle/
**/android/.cxx/
**/android/captures/
**/android/local.properties
**/*.iml
**/.externalNativeBuild/

# ────────────────────────────────────────────────────────────
# Native signing / keys (never commit)
# ────────────────────────────────────────────────────────────
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.keystore
*.mobileprovision

# ────────────────────────────────────────────────────────────
# Environment and credential files (never commit)
# ────────────────────────────────────────────────────────────
.env
.env.*
*.env
.env*.local
credentials.json
*token.json*
*credentials.json*
*.pem
*.key
.credentials

# ────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ────────────────────────────────────────────────────────────
# System files
# ────────────────────────────────────────────────────────────
.DS_Store

# ────────────────────────────────────────────────────────────
# Python (backend)
# ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
venv/
.venv/

